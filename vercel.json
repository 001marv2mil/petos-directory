{
  "crons": [
    {
      "path": "/api/outreach-cron",
      "schedule": "0 14 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.petosdirectory.com" }],
      "destination": "https://petosdirectory.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
