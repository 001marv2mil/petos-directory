{
  "name": "petos-directory",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && vite build --config vite.ssr.config.ts && node scripts/prerender.mjs && node scripts/prerender-providers.mjs",
    "build:client": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "seed": "tsx --env-file=.env.local scripts/seed-providers.ts",
    "ingest": "tsx --env-file=.env.local scripts/ingest-providers.ts",
    "outreach": "tsx --env-file=.env.local scripts/outreach.ts",
    "outreach:send": "tsx --env-file=.env.local scripts/outreach.ts --send"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-query": "^5.91.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.1",
    "resend": "^6.10.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.7.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
